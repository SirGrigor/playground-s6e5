# venv
.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/
.pytest_cache/

# data — files too big for git; downloaded via kaggle CLI
data/raw/
data/external/

# reference notebooks (downloaded from kaggle, not our code)
recon_notebooks/

# artifacts — regeneratable
probs/
submissions/
models/
catboost_info/

# harvested public kernel outputs — large CSVs, re-fetch via harvester scripts
harvest/v13/*/
# but keep the small metadata + verdict report
!harvest/v13/manifest.json
!harvest/v13/diversity_report.md

# v18 — bulk harvester output
harvest/v18/*/
!harvest/v18/manifest.json
!harvest/v18/audit.md

# scratch
/tmp_*
*.log
*.swp
.DS_Store

# only the split definition is tracked, not the data itself
!data/splits/
